DOTNET_NUGET_SIGNATURE_VERIFICATION=false
DOTNET_USE_POLLING_FILE_WATCHER=true
ASPNETCORE_LOGGING__CONSOLE__DISABLECOLORS=true
DOTNET_ReadyToRun=0
DOTNET_TC_QuickJitForLoops=1
DOTNET_TieredPGO=1
DOTNET_RUNNING_IN_CONTAINER=true
DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=1
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
APP_DOMAIN=core
DAPR_PLACEMENT_HOST=dapr-placement:50005
DAPR_HTTP_PORT=42110
DAPR_GRPC_PORT=42111
DAPR_SECRET_STORE_NAME=vnext-secret
DAPR_STATE_STORE_NAME=vnext-state
DAPR_PUBSUB_STORE_NAME=vnext-pubsub
DAPR_LOCK_STORE_NAME=vnext-lock
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=vnext-app
ConnectionStrings__Default=Host=vnext-postgres;Port=5432;Database=Aether_WorkflowDb;Username=postgres;Password=postgres;
Redis__Standalone__EndPoints__0=vnext-redis:6379
Telemetry__Otlp__Endpoint=http://otel-collector:4317
vNextApi__BaseUrl:http://vnext-app:5000