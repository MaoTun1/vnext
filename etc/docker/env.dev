# VNext Core Runtime Environment Variables - Development
# Development environment specific values

# VNext App URL - development environment
# Use host.docker.internal to access host machine from Docker container
# Use vnext-app:4201 when running with docker-compose
VNEXT_APP_URL=http://host.docker.internal:4201

# Application domain for development
APP_DOMAIN=dev

# VNext Core Runtime package version for development
VNEXT_CORE_RUNTIME_VERSION=latest