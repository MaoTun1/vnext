# VNext Core Runtime Environment Variables
# Default values for development environment

# VNext App URL - where the VNext application is running
# Use host.docker.internal to access host machine from Docker container
# Use vnext-app:4201 when running with docker-compose
VNEXT_APP_URL=http://host.docker.internal:4201

# Application domain for component initialization
APP_DOMAIN=core

# VNext Core Runtime package version
VNEXT_CORE_RUNTIME_VERSION=latest