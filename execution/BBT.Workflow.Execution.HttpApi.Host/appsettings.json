{
  "ApplicationName": "vnext-execution",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "OrchestrationApi": {
    "AppId": "vnext-app"
  },
  "TriggerRetry": {
    "MaxRetryAttempts": 3,
    "RetryDelayMilliseconds": 2000,
    "RetryOnStatusCodes": [409],
    "UseJitter": true
  },
  "ResponseCompression": {
    "Enable": true,
    "Providers": ["gzip"],
    "EnableForHttps": true,
    "MimeTypes": [],
    "ExcludedMimeTypes": []
  },
  "Redis": {
    "Mode": "Standalone",
    "InstanceName": "workflow-api",
    "ConnectionTimeout": 5000,
    "DefaultDatabase": 0,
    "Password": "",
    "Ssl": false,
    "Standalone": {
      "EndPoints": ["localhost:6379"]
    },
    "RetryPolicy": {
      "MaxRetries": 3,
      "RetryTimeout": 1000
    }
  },
  "Telemetry": {
    "ServiceName": "vnext-execution-app",
    "ServiceNamespace": "BBT.Workflow.Execution",
    "ServiceVersion": "1.0.0",
    "TracingEnabled": true,
    "MetricsEnabled": true,
    "LoggingEnabled": true,
    "Otlp": {
      "Endpoint": "http://localhost:4318",
      "Protocol": "http/protobuf"
    },
    "Tracing": {
      "EnableConsoleExporter": true,
      "EnableOtlpExporter": true,
      "ExcludedPaths": ["^/health$", "^/metrics$", "^/live$", "^/ready$", "^/swagger/*"],
      "AdditionalSources": ["BBT.Workflow.Execution*"],
      "Headers": ["sub", "act_sub", "jti", "role"]
    },
    "Metrics": {
      "EnableConsoleExporter": true,
      "EnableOtlpExporter": true,
      "AdditionalMeters": []
    },
    "Logging": {
      "EnableConsoleExporter": true,
      "EnableOtlpExporter": true,
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true,
      "ExcludedPaths": ["^/health$", "^/metrics$", "^/live$", "^/ready$", "^/swagger/*"],
      "Enrichers": {
        "Headers": ["sub", "act_sub", "jti", "role"],
        "CustomAttributes": {

        }
      },
      "Body": {
        "EnableRequestBody": false,
        "EnableResponseBody": false,
        "MaxBodyLengthToCapture": 16384,
        "AdditionalSensitiveJsonFields": [],
        "AdditionalSensitiveHeaderNames": []
      }
    }
  },
  "AllowedHosts": "*",
  "Vault": {
    "Enabled": false
  },
  "Dapr": {
    "Notification": {
      "ComponentName": "vnext-notification-binding",
      "DefaultOperation": "create",
      "TimeoutSeconds": 30
    }
  }
}
