{
  "ApplicationName": "vnext-db-migrator",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=vNext_MorphIdm;Username=postgres;Password=postgres;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "BBT.Workflow.DbMigrator": "Debug"
    }
  },
  "Runtime": {
    "EnableSchemaMigration": true
  },
  "Vault": {
    "Enabled": false
  },
  "Redis": {
    "Mode": "Standalone",
    "InstanceName": "workflow-api",
    "ConnectionTimeout": 5000,
    "DefaultDatabase": 0,
    "Password": "",
    "Ssl": false,
    "Standalone": {
      "EndPoints": ["localhost:6379"]
    },
    "RetryPolicy": {
      "MaxRetries": 3,
      "RetryTimeout": 1000
    }
  },
  "Telemetry": {
    "ServiceName": "vnext-db-migrator",
    "ServiceNamespace": "BBT.Workflow.DbMigrator",
    "ServiceVersion": "1.0.0",
    "TracingEnabled": true,
    "MetricsEnabled": true,
    "LoggingEnabled": true,
    "Otlp": {
      "Endpoint": "http://localhost:4318",
      "Protocol": "http/protobuf"
    },
    "Tracing": {
      "EnableConsoleExporter": true,
      "EnableOtlpExporter": true,
      "ExcludedPaths": ["^/health$", "^/metrics$", "^/live$", "^/ready$", "^/swagger/*"],
      "AdditionalSources": ["BBT.Workflow.DbMigrator"],
      "Headers": []
    },
    "Metrics": {
      "EnableConsoleExporter": true,
      "EnableOtlpExporter": true,
      "AdditionalMeters": []
    },
    "Logging": {
      "EnableConsoleExporter": true,
      "EnableOtlpExporter": true,
      "IncludeFormattedMessage": true,
      "IncludeScopes": true,
      "ParseStateValues": true,
      "ExcludedPaths": ["^/health$", "^/metrics$", "/live", "/ready", "/swagger/*"],
      "Enrichers": {
        "Headers": [],
        "CustomAttributes": {

        }
      },
      "Body": {
        "EnableRequestBody": false,
        "EnableResponseBody": false,
        "MaxBodyLengthToCapture": 16384,
        "AdditionalSensitiveJsonFields": [],
        "AdditionalSensitiveHeaderNames": []
      }
    }
  }
}
