    "compounds": [
        {
            "name": "🐳 Debug with Infrastructure (Docker Compose + VS Code)",
            "description": "Starts Docker Compose infrastructure and runs applications in debug mode within VS Code",
            "configurations": [
                "Orchestration with Docker Compose",
                "Execution with Docker Compose"
            ],
            "stopAll": true,
            "preLaunchTask": "build-all-and-docker-compose-up"
        },
        {
            "name": "🔧 Remote Debug (Docker Container Hot Reload)",
            "description": "Runs docker-compose.dev with applications in hot reload mode inside containers, allows remote debugging via VS Code attach",
            "configurations": [
                "Orchestration Debug with Docker Compose",
                "Execution Debug with Docker Compose"
            ],
            "stopAll": true,
            "preLaunchTask": "build-all-and-docker-compose-dev-up"
        },
        {
            "name": "⚡ Local Debug (Flexible Development)",
