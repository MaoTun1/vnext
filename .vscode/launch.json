    "version": "0.2.0",
    "configurations": [

        {
            "name": "Orchestration with Docker Compose",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-all-and-docker-compose-up",
            "program": "${workspaceFolder}/orchestration/BBT.Workflow.Orchestration.HttpApi.Host/bin/Debug/net9.0/BBT.Workflow.Orchestration.HttpApi.Host.dll",
            "args": [],
            "cwd": "${workspaceFolder}/orchestration/BBT.Workflow.Orchestration.HttpApi.Host",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "http://localhost:4201",
                "APP_DOMAIN": "core",
                "DAPR_HTTP_PORT": "42110",
                "DAPR_GRPC_PORT": "42111",
                "DAPR_PLACEMENT_HOST": "localhost:50005",
                "OTEL_EXPORTER_OTLP_ENDPOINT": "http://localhost:4318",
                "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
                "OTEL_SERVICE_NAME": "vnext-app",
                "DAPR_SECRET_STORE_NAME": "vnext-secret",
                "DAPR_STATE_STORE_NAME": "vnext-state",
                "DAPR_PUBSUB_STORE_NAME": "vnext-pubsub",
                "DAPR_PUBSUB_BROADCAST_STORE_NAME": "vnext-pubsub-broadcast",
                "DAPR_LOCK_STORE_NAME": "vnext-lock"
            },
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/swagger/"
            }
        },
        {
            "name": "Execution with Docker Compose",
            "type": "coreclr",
            "request": "launch",
